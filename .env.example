# Bloom — environment variable overrides (optional)
# All values shown are defaults. Most users should NOT need to edit anything here;
# `bloom-mcp init` writes the canonical config to ~/.bloom/config.toml.

# Where Bloom stores its SQLite database. Default: ~/.bloom/loom.db
# BLOOM_DB_PATH=

# Embedding provider for semantic recall. Options: none | openai | anthropic | local
# Default is "none" — keyword-based recall works offline with zero API keys.
# BLOOM_EMBEDDER=none

# Provider API keys — only required if you choose a paid embedder.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=

# Log level: DEBUG | INFO | WARNING | ERROR
# BLOOM_LOG_LEVEL=INFO
